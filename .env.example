# Copier ce fichier en .env et remplir les valeurs

# Notification Slack (optionnel : si absent, l'alerting logue et continue)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Cle API Gemini pour les explications LLM (optionnel : fallback template si absent)
GEMINI_API_KEY=your_gemini_api_key_here

# Cle CI pour l'API de deploiements (spec 12). Si definie, POST /deploys exige
# l'en-tete X-API-Key ; le scenario-runner et scripts/demo.sh l'envoient
# automatiquement s'ils voient DEPLOY_API_KEY. Absente -> mode dev non authentifie.
DEPLOY_API_KEY=your_ci_deploy_key_here

# --- Surcharges optionnelles ------------------------------------------------
# Utilisees quand on lance scraper.py / detector.py / baseline_job.py / evaluation.py
# a la main sur l'hote. En conteneur, docker-compose fournit deja ces valeurs.
# DATABASE_URL=postgresql://cassandra:cassandra@localhost:5434/cassandra
# PROMETHEUS_URL=http://127.0.0.1:9090
