    {
      "type": "stat",
      "title": "Fraicheur scraper (s)",
      "datasource": {
        "type": "postgres",
        "uid": "DS_TIMESCALEDB"
      },
      "description": "Age de la derniere ligne endpoint_features. Rouge > 300s = scraper en retard (lag alert).",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 120
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "DS_TIMESCALEDB"
          },
          "rawQuery": true,
          "rawSql": "SELECT now() AS time, EXTRACT(EPOCH FROM (now()-max(time)))::int AS value FROM endpoint_features",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
