        "name": "RESOLVED alerts",
        "rawQuery": true,
        "rawSql": "SELECT resolved_at AS time, endpoint_id || ' RESOLVED' AS text, 'RESOLVED' AS tags FROM alerts WHERE resolved_at IS NOT NULL AND resolved_at BETWEEN $__timeFrom() AND $__timeTo() AND endpoint_id = '$endpoint' ORDER BY resolved_at",
        "showIn": 0,
        "type": "tags"
      },
      {
        "datasource": {
          "type": "postgres",
          "uid": "DS_TIMESCALEDB"
