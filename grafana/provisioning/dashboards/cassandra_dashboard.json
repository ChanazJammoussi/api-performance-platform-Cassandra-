        "rawSql": "SELECT deployed_at AS time, service || ' ' || version AS text, 'deploy' AS tags FROM deploy_events WHERE deployed_at BETWEEN $__timeFrom() AND $__timeTo() ORDER BY deployed_at",
        "showIn": 0,
        "type": "tags"
      }
    ]
