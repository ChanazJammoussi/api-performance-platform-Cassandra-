          "rawQuery": true,
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT fault_type, dr_static AS \"static\", dr_layered AS \"layered\" FROM eval_runs WHERE fault_type<>'OVERALL' AND run_id=(SELECT run_id FROM eval_runs ORDER BY run_at DESC LIMIT 1) ORDER BY fault_type"
